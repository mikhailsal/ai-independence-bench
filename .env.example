# OpenRouter API Key (get from https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-your-key-here

# Custom proxy support (ai-proxy2 or compatible OpenAI-API proxy)
# OPENROUTER_KEY overrides OPENROUTER_API_KEY when set.
# OPENROUTER_BASE_URL redirects all API calls through the proxy.
# OPENROUTER_KEY=your-proxy-key-here
# OPENROUTER_BASE_URL=http://localhost:8000/v1

# Local model support (LM Studio, Ollama, etc.)
# Uncomment and set these to run the benchmark against a local model.
# LOCAL_MODEL_URL=http://192.168.1.101:1234/v1
# LOCAL_MODEL_ID=qwen3.5-9b-uncensored-hauhaucs-aggressive
